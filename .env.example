# Klaviyo (required for /api/subscribe)
# Settings → API keys → Create private API key (or edit scopes on an existing key).
# Required scopes — all three: lists:write, profiles:write, subscriptions:write
# (If you see "missing required scopes: subscriptions:write", enable it here and update Vercel.)
KLAVIYO_PRIVATE_API_KEY=

# List ID from the list URL in Klaviyo (short id only, no spaces)
KLAVIYO_LIST_ID=

# Vercel: add both vars for Production (and Preview if you test preview URLs), then redeploy.
